<UserControl x:Class="nvGPUMonitor.Controls.DualDonutGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="192" MinHeight="192">
  <Grid>
    <!-- Background ring -->
    <Path x:Name="ArcBg" StrokeThickness="24" Stroke="#E5E5EA" Fill="Transparent" />
    
    <!-- Inner ring (Value2 - RX in green) -->
    <Path x:Name="ArcPath2" StrokeThickness="12" StrokeEndLineCap="Round" Fill="Transparent" />
    
    <!-- Outer ring (Value1 - TX in orange) -->
    <Path x:Name="ArcPath1" StrokeThickness="12" StrokeEndLineCap="Round" Fill="Transparent" />
    
    <Grid x:Name="Overlay" VerticalAlignment="Center" HorizontalAlignment="Center">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <TextBlock x:Name="CaptionText" Grid.Row="0" Text="LABEL" FontSize="28" FontWeight="Bold"
                 HorizontalAlignment="Stretch" TextAlignment="Center"/>
      
      <!-- TX Line (Orange) -->
      <TextBlock x:Name="Value1Text" Grid.Row="1" Text="TX: 0%" FontSize="16" FontWeight="SemiBold"
                 HorizontalAlignment="Stretch" TextAlignment="Center" Margin="0,4,0,0"/>
      
      <!-- RX Line (Green) -->
      <TextBlock x:Name="Value2Text" Grid.Row="2" Text="RX: 0%" FontSize="16" FontWeight="SemiBold"
                 HorizontalAlignment="Stretch" TextAlignment="Center" Margin="0,2,0,0"/>
      
      <!-- Detail line -->
      <TextBlock x:Name="DetailText" Grid.Row="3" Text="" FontSize="13" Foreground="#666"
                 HorizontalAlignment="Stretch" TextAlignment="Center" Margin="0,2,0,0"/>
    </Grid>
  </Grid>
</UserControl>
