<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <?define ProductVersion="0.6.0.0" ?>
  <?define ProductName="nvGPUMonitor" ?>
  <?define Manufacturer="nvGPUMonitor contributors" ?>
  <?define UpgradeCode="F2038F5D-63D3-46E0-A621-54079172E2B9" ?>
  
  <Product Id="*" 
           Name="$(var.ProductName)" 
           Language="1033" 
           Version="$(var.ProductVersion)" 
           Manufacturer="$(var.Manufacturer)" 
           UpgradeCode="$(var.UpgradeCode)">
    
    <Package InstallerVersion="200" 
             Compressed="yes" 
             InstallScope="perMachine" 
             Description="NVIDIA GPU Monitor Application"
             Comments="Monitors GPU, CPU, RAM, VRAM, PCIe, Decoder and Encoder metrics" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="nvGPUMonitor" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="ApplicationShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- UI with license agreement -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />

    <!-- Icons -->
    <Icon Id="nvGPUMonitor.ico" SourceFile="nvGPUMonitor.ico"/>
    <Property Id="ARPPRODUCTICON" Value="nvGPUMonitor.ico" />
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="nvGPUMonitor" />
      </Directory>
      
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="nvGPUMonitor"/>
      </Directory>
      
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <!-- Main executable -->
      <Component Id="nvGPUMonitorExe" Guid="*">
        <File Id="nvGPUMonitor.exe" 
              Source="$(var.PublishDir)\nvGPUMonitor.exe" 
              KeyPath="yes" />
      </Component>
      
      <!-- All DLL files from publish folder -->
      <Component Id="AllDLLs" Guid="*">
        <File Id="nvGPUMonitor.dll" Source="$(var.PublishDir)\nvGPUMonitor.dll" />
      </Component>
      
      <!-- Runtime config -->
      <Component Id="RuntimeConfig" Guid="*">
        <File Id="nvGPUMonitor.runtimeconfig.json" 
              Source="$(var.PublishDir)\nvGPUMonitor.runtimeconfig.json" />
      </Component>
      
      <!-- Dependencies config -->
      <Component Id="DepsConfig" Guid="*">
        <File Id="nvGPUMonitor.deps.json" 
              Source="$(var.PublishDir)\nvGPUMonitor.deps.json" />
      </Component>

      <!-- LICENSE file -->
      <Component Id="LicenseFile" Guid="*">
        <File Id="LICENSE" Source="LICENSE" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Start Menu Shortcut -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="nvGPUMonitor"
                  Description="NVIDIA GPU Monitor"
                  Target="[INSTALLFOLDER]nvGPUMonitor.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="nvGPUMonitor.ico" />
        <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall"/>
        <RegistryValue Root="HKCU" 
                       Key="Software\[Manufacturer]\[ProductName]" 
                       Name="installed" 
                       Type="integer" 
                       Value="1" 
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- Desktop Shortcut -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="*">
        <Shortcut Id="ApplicationDesktopShortcut"
                  Name="nvGPUMonitor"
                  Description="NVIDIA GPU Monitor"
                  Target="[INSTALLFOLDER]nvGPUMonitor.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="nvGPUMonitor.ico" />
        <RemoveFolder Id="CleanUpDesktopShortcut" Directory="DesktopFolder" On="uninstall"/>
        <RegistryValue Root="HKCU" 
                       Key="Software\[Manufacturer]\[ProductName]" 
                       Name="desktopShortcut" 
                       Type="integer" 
                       Value="1" 
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
