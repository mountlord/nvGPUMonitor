<Window x:Class="nvGPUMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:g="clr-namespace:nvGPUMonitor.Controls"
        Title="nvGPUMonitor" Height="720" Width="1000">
  <Window.Resources>
    <SolidColorBrush x:Key="Line1" Color="#888888"/>
    <SolidColorBrush x:Key="Line2" Color="#C9C9CE"/>
    <SolidColorBrush x:Key="Line3" Color="#E6E6EA"/>

    <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
      <Setter Property="BorderBrush" Value="{StaticResource Line1}"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Background" Value="#F7F7FA"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="RowStyle" TargetType="DataGridRow">
      <Setter Property="BorderBrush" Value="{StaticResource Line2}"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="CellText" TargetType="TextBlock">
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CellW1" TargetType="DataGridCell">
      <Setter Property="BorderBrush" Value="{StaticResource Line1}"/>
      <Setter Property="BorderThickness" Value="0,0,2,0"/>
    </Style>
    <Style x:Key="CellW2" TargetType="DataGridCell">
      <Setter Property="BorderBrush" Value="{StaticResource Line2}"/>
      <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>
    <Style x:Key="CellW3" TargetType="DataGridCell">
      <Setter Property="BorderBrush" Value="{StaticResource Line3}"/>
      <Setter Property="BorderThickness" Value="0,0,0.5,0"/>
    </Style>
  </Window.Resources>

  <Grid Background="#FAFAFC" Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Text="NGPU Monitor — v0.5.0" FontSize="20" FontWeight="SemiBold" Margin="4" />

    <UniformGrid Grid.Row="1" Columns="6" Margin="0,16,0,0">
      <g:DonutGauge Caption="GPU"  Value="{Binding GpuLoad}"  Detail="{Binding GpuDetail}"
                    CaptionOffsetX="0" CaptionOffsetY="40"
                    ValueOffsetX="0"   ValueOffsetY="40"
                    DetailOffsetX="0"  DetailOffsetY="40"/>
      <g:DonutGauge Caption="VRAM" Value="{Binding VramLoad}" Detail="{Binding VramDetail}"
                    CaptionOffsetX="0" CaptionOffsetY="40"
                    ValueOffsetX="0"   ValueOffsetY="40"
                    DetailOffsetX="0"  DetailOffsetY="40"/>
      <g:DualDonutGauge Caption="PCIe" 
                        Value1="{Binding PcieTxLoad}" 
                        Value2="{Binding PcieRxLoad}"
                        Label1="TX" Label2="RX"
                        Arc1Brush="#FF6B35" Arc2Brush="#00C896"
                        Detail="{Binding PcieDetail}"
                        CaptionOffsetX="0" CaptionOffsetY="40"
                        ValueOffsetX="0"   ValueOffsetY="40"
                        DetailOffsetX="0"  DetailOffsetY="40"/>
      <g:DonutGauge Caption="Free Space" Value="{Binding TempDirLoad}" Detail="{Binding TempDirDetail}"
                    ArcBrush="{Binding TempDirBrush}"
                    CaptionOffsetX="0" CaptionOffsetY="40"
                    ValueOffsetX="0"   ValueOffsetY="40"
                    DetailOffsetX="0"  DetailOffsetY="40"/>
      <g:DonutGauge Caption="CPU"  Value="{Binding CpuLoad}"  Detail="{Binding CpuSummary}"
                    CaptionOffsetX="0" CaptionOffsetY="40"
                    ValueOffsetX="0"   ValueOffsetY="40"
                    DetailOffsetX="0"  DetailOffsetY="40"/>
      <g:DonutGauge Caption="RAM"  Value="{Binding RamLoad}"  Detail="{Binding RamDetail}"
                    CaptionOffsetX="0" CaptionOffsetY="40"
                    ValueOffsetX="0"   ValueOffsetY="40"
                    DetailOffsetX="0"  DetailOffsetY="40"/>
    </UniformGrid>

    <Border Grid.Row="2" Margin="0,16,0,16" Padding="0" CornerRadius="8"
            Background="White" BorderBrush="{StaticResource Line1}" BorderThickness="2">
      <DataGrid ItemsSource="{Binding TableRows}" AutoGenerateColumns="False" HeadersVisibility="Column"
                CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                GridLinesVisibility="None" ColumnHeaderHeight="34"
                RowStyle="{StaticResource RowStyle}" ColumnHeaderStyle="{StaticResource HeaderStyle}">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Time" Binding="{Binding ColT}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW1}" Width="110"/>
          <DataGridTextColumn Header="GPU Load"  Binding="{Binding Col0}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW3}"/>
          <DataGridTextColumn Header="GPU Temp"  Binding="{Binding Col1}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW3}"/>
          <DataGridTextColumn Header="GPU Clock" Binding="{Binding Col2}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW1}"/>
          <DataGridTextColumn Header="VRAM"      Binding="{Binding Col3}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW1}"/>
          <DataGridTextColumn Header="PCIe TX"   Binding="{Binding Col9}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW3}"/>
          <DataGridTextColumn Header="PCIe RX"   Binding="{Binding Col10}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW1}"/>
          <DataGridTextColumn Header="CPU Load"  Binding="{Binding Col4}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW3}"/>
          <DataGridTextColumn Header="CPU Temp"  Binding="{Binding Col5}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW3}"/>
          <DataGridTextColumn Header="CPU Clock" Binding="{Binding Col6}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW1}"/>
          <DataGridTextColumn Header="RAM"       Binding="{Binding Col7}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW1}"/>
          <DataGridTextColumn Header="Py Aggregate" Binding="{Binding Col8}" ElementStyle="{StaticResource CellText}" CellStyle="{StaticResource CellW1}"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <TextBlock Text="Update Interval:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
      <ComboBox x:Name="IntervalComboBox" Width="100" Margin="0,0,16,0" SelectionChanged="IntervalComboBox_SelectionChanged">
        <ComboBoxItem Content="0.1 sec" Tag="100"/>
        <ComboBoxItem Content="0.2 sec" Tag="200"/>
        <ComboBoxItem Content="0.3 sec" Tag="300"/>
        <ComboBoxItem Content="0.4 sec" Tag="400"/>
        <ComboBoxItem Content="0.5 sec" Tag="500"/>
        <ComboBoxItem Content="0.6 sec" Tag="600"/>
        <ComboBoxItem Content="0.7 sec" Tag="700"/>
        <ComboBoxItem Content="0.8 sec" Tag="800"/>
        <ComboBoxItem Content="0.9 sec" Tag="900"/>
        <ComboBoxItem Content="1.0 sec" Tag="1000" IsSelected="True"/>
        <ComboBoxItem Content="2.0 sec" Tag="2000"/>
        <ComboBoxItem Content="3.0 sec" Tag="3000"/>
        <ComboBoxItem Content="4.0 sec" Tag="4000"/>
        <ComboBoxItem Content="5.0 sec" Tag="5000"/>
      </ComboBox>
      <Button Content="Folder To Monitor" Width="140" Margin="4" Click="SelectTempDir_Click"/>
      <Button Content="Start Log" Width="120" Margin="4" Click="StartLog_Click"/>
      <Button Content="Stop Log" Width="120" Margin="4" Click="StopLog_Click"/>
    </StackPanel>
  </Grid>
</Window>